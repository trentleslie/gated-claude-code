#!/usr/bin/env bash
# installed at /opt/gate/run-analysis (root:cs-exec, 0750). Runs as cs-exec.
# The untrusted script is sandboxed INSIDE run-analysis (bubblewrap around the child
# only); this wrapper just pins the trusted paths so cs-gated cannot choose them.
set -euo pipefail
SCRIPT="$1"
DATA_DIR=/data/arivale                       # hardcoded, never from env/args
OUT_DIR="$(mktemp -d /var/gate/out.XXXXXX)"
exec run-analysis "$SCRIPT" \
  --data-dir "$DATA_DIR" \
  --out-dir "$OUT_DIR" \
  --audit /var/gate/audit.jsonl \
  --queue /var/gate/queue
