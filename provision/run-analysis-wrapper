#!/usr/bin/env bash
# installed at /opt/gate/run-analysis (root:cs-exec, 0750). Runs as cs-exec.
# Sandbox is INSIDE run-analysis (bubblewrap around the untrusted child only); this
# wrapper pins trusted paths and scrubs the environment so cs-gated cannot influence
# execution.
set -euo pipefail
SCRIPT="$1"
DATA_DIR=__GATED_CS_DATA_DIR__               # baked in at install by provision.sh; never from env/args
OUT_DIR="$(mktemp -d /var/gate/out.XXXXXX)"
exec env -i \
  PATH=/opt/gated-cs/bin:/usr/local/bin:/usr/bin:/bin \
  GATED_CS_REQUIRE_SANDBOX=1 \
  run-analysis "$SCRIPT" \
    --data-dir "$DATA_DIR" \
    --out-dir "$OUT_DIR" \
    --audit /var/gate/audit.jsonl \
    --queue /var/gate/queue \
    --results /var/gate/results
