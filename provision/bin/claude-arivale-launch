#!/usr/bin/env bash
# Launch the gated Arivale analyst as the cs-gated user. `--t <minutes>` sets the gate's analysis compute
# timeout (operator-only: written to a root-owned config the gate reads, clamped to 1-60 min); absent --t
# it resets to the 120s default. All other args are passed through to claude.
CONF=/etc/gated-cs/gate_timeout_seconds
mins=""; rest=()
while [ $# -gt 0 ]; do
  case "$1" in
    --t) mins="${2:-}"; shift 2 ;;
    --t=*) mins="${1#--t=}"; shift ;;
    *) rest+=("$1"); shift ;;
  esac
done
if [ -n "$mins" ]; then
  case "$mins" in ''|*[!0-9]*) echo "claude-arivale: --t needs whole minutes (e.g. --t 20)" >&2; exit 2 ;; esac
  [ "$mins" -lt 1 ] && mins=1; [ "$mins" -gt 60 ] && mins=60
  secs=$((mins * 60))
else
  secs=120
fi
if mkdir -p "$(dirname "$CONF")" 2>/dev/null && printf '%s\n' "$secs" > "$CONF" 2>/dev/null; then
  chmod 0644 "$CONF" 2>/dev/null || true
  echo "gate analysis timeout: ${secs}s"
else
  echo "warning: could not write $CONF (run as root to use --t); gate keeps its current timeout" >&2
fi
exec sudo -iu cs-gated env CLAUDE_FLAGS="${rest[*]}" bash -lc \
  'export PATH="$HOME/.local/bin:/usr/local/bin:$PATH"; cd ~/analysis && exec claude $CLAUDE_FLAGS'
